# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
ENV=development
DEBUG=True

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/news_intelligence
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=news-intelligence-bucket
LAMBDA_INGESTION_FUNCTION=news-ingestion
LAMBDA_PROCESSING_FUNCTION=news-processing

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.7

# News Sources
NEWS_API_KEY=your_newsapi_key
GUARDIAN_API_KEY=your_guardian_api_key
NYTIMES_API_KEY=your_nytimes_api_key

# Sentiment Analysis
SENTIMENT_MODEL_PATH=./models/sentiment-model
TOPIC_MODEL_PATH=./models/topic-model

# Monitoring
LOG_LEVEL=INFO
CLOUDWATCH_GROUP=/aws/lambda/news-intelligence
CLOUDWATCH_STREAM=ingestion

# Performance
MAX_CONCURRENT_REQUESTS=100
REQUEST_TIMEOUT=30
CACHE_TTL=3600

# Security
JWT_SECRET=your_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600
CORS_ORIGINS=["http://localhost:3000", "https://yourdomain.com"]
